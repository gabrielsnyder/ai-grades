generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum IndicatorType {
  BILL_VOTE
  PUBLIC_STATEMENT
  CAMPAIGN_STATEMENT
  CUSTOM
}

enum ReviewStatus {
  UNVERIFIED
  MACHINE_VERIFIED
  AUTO_CORRECTED
  FLAGGED
  HUMAN_REVIEWED
}

enum Origin {
  AGENT
  HUMAN
}

enum AgentRunType {
  CANDIDATE_FINDER
  RESEARCHER
  ASSESSOR
  VERIFIER
}

enum AgentRunStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

enum SourceStatus {
  FOUND
  VERIFIED
  REJECTED
}

enum FlagStatus {
  OPEN
  RESOLVED
}

model Candidate {
  id           String          @id @default(cuid())
  name         String
  state        String
  party        String
  groupId      String?
  office       String?
  electionYear Int?
  externalId   String?
  group        CandidateGroup? @relation(fields: [groupId], references: [id])
  assessments  Assessment[]
  sources      Source[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([groupId])
}

model CandidateGroup {
  id          String      @id @default(cuid())
  name        String
  description String?
  candidates  Candidate[]
  indicators  Indicator[]
}

model Question {
  id          String      @id @default(cuid())
  text        String
  description String?
  shortLabel  String?
  order       Int
  indicators  Indicator[]

  @@index([order])
}

model Indicator {
  id               String          @id @default(cuid())
  questionId       String
  question         Question        @relation(fields: [questionId], references: [id])
  name             String
  type             IndicatorType
  rubric           String          @db.Text
  rubricVersion    Int             @default(1)
  weight           Float?
  meta             Json?
  chamber          String?         // 'SENATE' | 'HOUSE' | null (chamber-agnostic)
  appliesToGroupId String?
  appliesToGroup   CandidateGroup? @relation(fields: [appliesToGroupId], references: [id])
  assessments      Assessment[]

  @@unique([questionId, type, name])
  @@index([questionId])
}

model WeightingProfile {
  id          String       @id @default(cuid())
  name        String
  isActive    Boolean      @default(false)
  typeWeights TypeWeight[]
}

model TypeWeight {
  id        String           @id @default(cuid())
  profileId String
  profile   WeightingProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  type      IndicatorType
  weight    Float

  @@unique([profileId, type])
}

model Assessment {
  id             String             @id @default(cuid())
  candidateId    String
  indicatorId    String
  candidate      Candidate          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  indicator      Indicator          @relation(fields: [indicatorId], references: [id])
  value          Int?
  rationale      String?            @db.Text
  weightOverride Float?
  reviewStatus   ReviewStatus       @default(UNVERIFIED)
  origin         Origin             @default(AGENT)
  agentRunId     String?
  agentRun       AgentRun?          @relation(fields: [agentRunId], references: [id])
  rubricVersion  Int                @default(1)
  supersedesId   String?
  supersedes     Assessment?        @relation("Supersession", fields: [supersedesId], references: [id])
  supersededBy   Assessment[]       @relation("Supersession")
  sources        AssessmentSource[]
  corrections    Correction[]
  flags          Flag[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([candidateId, indicatorId])
  @@index([candidateId])
  @@index([indicatorId])
}

model Source {
  id          String             @id @default(cuid())
  candidateId String
  candidate   Candidate          @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  url         String?
  title       String?
  excerpt     String?            @db.Text
  publishedAt DateTime?
  status      SourceStatus       @default(FOUND)
  agentRunId  String?
  agentRun    AgentRun?          @relation(fields: [agentRunId], references: [id])
  assessments AssessmentSource[]
  corrections Correction[]
  flags       Flag[]
  createdAt   DateTime           @default(now())

  @@index([candidateId])
}

model AssessmentSource {
  assessmentId String
  sourceId     String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  source       Source     @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@id([assessmentId, sourceId])
}

model AgentRun {
  id               String         @id @default(cuid())
  type             AgentRunType
  status           AgentRunStatus @default(QUEUED)
  scope            Json?
  provider         String?
  model            String?
  dryRun           Boolean        @default(false)
  costInputTokens  Int?
  costOutputTokens Int?
  searchCount      Int            @default(0)
  cacheHitCount    Int            @default(0)
  error            String?        @db.Text
  startedAt        DateTime?
  finishedAt       DateTime?
  createdAt        DateTime       @default(now())
  assessments      Assessment[]
  sources          Source[]
  corrections      Correction[]
  flags            Flag[]
}

model Correction {
  id           String      @id @default(cuid())
  agentRunId   String
  agentRun     AgentRun    @relation(fields: [agentRunId], references: [id])
  assessmentId String?
  assessment   Assessment? @relation(fields: [assessmentId], references: [id])
  sourceId     String?
  source       Source?     @relation(fields: [sourceId], references: [id])
  check        String
  field        String
  before       String?     @db.Text
  after        String?     @db.Text
  confidence   Float
  createdAt    DateTime    @default(now())
}

model Flag {
  id           String      @id @default(cuid())
  agentRunId   String
  agentRun     AgentRun    @relation(fields: [agentRunId], references: [id])
  targetType   String
  targetId     String
  assessmentId String?
  assessment   Assessment? @relation(fields: [assessmentId], references: [id])
  sourceId     String?
  source       Source?     @relation(fields: [sourceId], references: [id])
  reason       String      @db.Text
  severity     String
  confidence   Float
  status       FlagStatus  @default(OPEN)
  createdAt    DateTime    @default(now())
}

model SearchCache {
  id              String    @id @default(cuid())
  query           String
  normalizedQuery String
  results         Json
  resultCount     Int       @default(0)
  source          String    @default("SERPER")
  fetchedAt       DateTime  @default(now())
  expiresAt       DateTime?
  hitCount        Int       @default(0)
  candidateId     String?
  indicatorId     String?

  @@index([normalizedQuery])
  @@index([candidateId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(EDITOR)
  createdAt    DateTime @default(now())
}

enum UserRole {
  ADMIN
  EDITOR
}
